# Now Playing Widget - Environment Variables
# Copy this file to .env and fill in your values

# Spotify application credentials for this hosted app.
# Get these from https://developer.spotify.com/dashboard/applications
# Add this redirect URI in your Spotify app:
# http://127.0.0.1:5000/callback

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_SECRET_ID=your_spotify_client_secret_here

# Public base URL used when generating markdown.
APP_BASE_URL=http://127.0.0.1:5000

# Optional. Defaults to APP_BASE_URL/callback.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/callback

# Required for production. Generate a long random string.
SECRET_KEY=change-this-secret

# SQLite token store. Use a persistent path on Docker/VM hosts.
TOKEN_DB_PATH=./data/spotify-users.sqlite3
